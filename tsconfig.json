{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "src/**/*.astro", "src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["dist", "src/**/*.tsx", "src/**/*.jsx"],
  "compilerOptions": {
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"],
    "paths": {
      "@/*": ["src/*"]
    }
  }
}
